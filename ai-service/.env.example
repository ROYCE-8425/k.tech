# =============================================================================
# AI Service — Environment Configuration
# =============================================================================

# ---------------------------------------------------------------------------
# Provider Selection
# ---------------------------------------------------------------------------
# Which LLM provider to use for structured extraction (CV/JD parsing).
# Supported values: openai, gemini, xai (grok is an alias for xai)
#
# If not set, auto-detects from available API keys (OpenAI first).
# If no provider is configured, extraction falls back to heuristic keywords.
# Deterministic scoring is NOT affected by provider choice.
LLM_PROVIDER=openai

# ---------------------------------------------------------------------------
# OpenAI (default)
# ---------------------------------------------------------------------------
# Required if LLM_PROVIDER=openai or auto-detect is used.
# Falls back to heuristic extraction if missing.
#
# IMPORTANT: OPENAI_API_KEY is also used for embedding generation (pgvector
# retrieval), REGARDLESS of which LLM_PROVIDER is selected. If you use
# LLM_PROVIDER=gemini or xai but still want vector-backed retrieval,
# you MUST also set OPENAI_API_KEY.
OPENAI_API_KEY=sk-...

# Extraction model (must support JSON mode / structured output)
# Defaults to gpt-4o-mini if not set
OPENAI_EXTRACTION_MODEL=gpt-4o-mini

# General model override (used by other agents if they read OPENAI_MODEL)
OPENAI_MODEL=gpt-4o-mini

# ---------------------------------------------------------------------------
# Google Gemini
# ---------------------------------------------------------------------------
# Required if LLM_PROVIDER=gemini
# Requires: pip install google-generativeai
GEMINI_API_KEY=
GEMINI_EXTRACTION_MODEL=gemini-2.0-flash

# ---------------------------------------------------------------------------
# xAI / Grok
# ---------------------------------------------------------------------------
# Required if LLM_PROVIDER=xai or LLM_PROVIDER=grok
# Uses OpenAI-compatible API at api.x.ai (reuses openai SDK)
XAI_API_KEY=
XAI_EXTRACTION_MODEL=grok-3-mini
XAI_BASE_URL=https://api.x.ai/v1

# ---------------------------------------------------------------------------
# Embedding / RAG (provider-independent)
# ---------------------------------------------------------------------------
# Embedding model for pgvector-backed retrieval grounding.
# Uses OPENAI_API_KEY for embedding generation (OpenAI Embeddings API).
# Defaults to text-embedding-3-small (1536 dimensions).
EMBEDDING_MODEL=text-embedding-3-small

# ---------------------------------------------------------------------------
# Database — PostgreSQL for knowledge corpus (pgvector retrieval)
# ---------------------------------------------------------------------------
# The AI service uses this to store/retrieve knowledge documents for RAG.
# This is SEPARATE from the Laravel backend's database config.
#
# Requirements for full pgvector retrieval:
#   1. PostgreSQL 14+ with pgvector extension installed
#   2. DATABASE_URL pointing to the correct database
#   3. OPENAI_API_KEY set (for embedding generation)
#
# If any of these are missing, retrieval gracefully degrades:
#   - No DATABASE_URL → static in-memory corpus
#   - DB connected but no pgvector → keyword search fallback
#   - DB + pgvector but no OPENAI_API_KEY → keyword search (no embeddings)
#   - All available → pgvector vector similarity search

# Docker Compose (default):
DATABASE_URL=postgresql://cvmatcher:cvmatcher@postgres:5432/recruitment_app

# VPS / bare-metal deployment:
# DATABASE_URL=postgresql://cvmatcher:cvmatcher@localhost:5432/recruitment_app

# Local development (via Docker exposed port):
# DATABASE_URL=postgresql://cvmatcher:cvmatcher@localhost:5433/recruitment_app

# ---------------------------------------------------------------------------
# Retrieval Control
# ---------------------------------------------------------------------------
# Force static-only retrieval (bypass DB entirely).
# Useful for debugging or environments without PostgreSQL.
# Default: false
RETRIEVAL_FALLBACK_ONLY=false

# ---------------------------------------------------------------------------
# Feedback Reranker
# ---------------------------------------------------------------------------
# Enable/disable feedback-derived score adjustments.
# Default: true
FEEDBACK_RERANK_ENABLED=true

# ---------------------------------------------------------------------------
# Runtime
# ---------------------------------------------------------------------------
APP_ENV=local
LOG_LEVEL=info

# ---------------------------------------------------------------------------
# Fallback Behavior Summary
# ---------------------------------------------------------------------------
# If no LLM_PROVIDER is set and no API key is found:
#   → ExtractionService uses FallbackExtractor (keyword heuristics)
#   → extraction_confidence will be "low" or "medium"
#   → risk_flags will note "Heuristic extraction used"
#   → fit_score is still computed deterministically
#   → Pipeline remains functional — no crash
#
# If DATABASE_URL is not set or DB is unreachable:
#   → RAGAgent uses static in-memory corpus (3 documents)
#   → retrieval_method will be "fallback_static"
#   → Matching still works — just with less grounding context
#
# Both fallbacks can be active simultaneously — the service always starts.
